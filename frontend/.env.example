# =============================================================
# TEG+ Frontend - Exemplo de Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# =============================================================

# --- Supabase (público - seguro no frontend) ---
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon...

# --- n8n Webhooks ---
# URL base do seu servidor n8n
VITE_N8N_BASE_URL=https://seu-n8n.easypanel.host
# URL base dos webhooks (geralmente BASE_URL + /webhook)
VITE_N8N_WEBHOOK_URL=https://seu-n8n.easypanel.host/webhook

# --- Push Notifications (Web Push / VAPID) ---
# Par de chaves JÁ provisionado: esta chave pública está hardcoded na edge function
# send-push e a private correspondente vive no Vault (VAPID_PRIVATE_KEY, lido via
# RPC get_secret). Não regenerar sem atualizar ambos, senão os pushes falham.
VITE_VAPID_PUBLIC_KEY=BBxTOl-a41Qz4pjvF078WsTWxNmJKKTyLeKB9YWEjmWmDpaEjrpWKUMmn3ZuakkFjjYiZ47wGT0b221GQOrP8Ks
