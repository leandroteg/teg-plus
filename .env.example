# =============================================================
# TEG+ - Template de variáveis de ambiente
# Copiar para .env e preencher com as credenciais reais
# =============================================================

# --- SUPABASE ---
SUPABASE_URL=https://SEU-PROJECT-ID.supabase.co
SUPABASE_PROJECT_REF=SEU-PROJECT-ID
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key...
SUPABASE_ANON_KEY=eyJ...anon_key...

# --- POSTGRESQL DIRETO ---
DATABASE_URL=postgresql://postgres:SENHA@db.SEU-PROJECT-ID.supabase.co:5432/postgres
DB_HOST=db.SEU-PROJECT-ID.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=SUA_SENHA

# --- N8N ---
N8N_BASE_URL=https://seu-n8n.easypanel.host
N8N_WEBHOOK_URL=https://seu-n8n.easypanel.host/webhook
N8N_API_URL=https://seu-n8n.easypanel.host/api/v1
N8N_API_KEY=eyJ...n8n_api_key...
