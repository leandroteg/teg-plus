# ─── Conexão com o Supabase do TEG+ (produção) ───────────────────────────────
SUPABASE_URL=https://uzfjfucrinokeuwpbeie.supabase.co
# Chave service_role (SECRETA). Supabase → Project Settings → API → service_role.
# NUNCA versionar / NUNCA expor no frontend. Só este worker on-prem a usa.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Canal WhatsApp ──────────────────────────────────────────────────────────
# Liga o canal no boot. Se !=true, o worker sobe mas só conecta via comando
# "Conectar" no painel (/ti → Configurações → WhatsApp).
WHATSAPP_ENABLED=true

# Janela (min) do "um chamado por conversa": mensagens dentro desse tempo viram
# COMENTÁRIO no mesmo chamado em vez de abrir outro. Padrão 360 (6h).
WHATSAPP_CONVERSA_JANELA_MIN=360

# Conta de sistema usada como solicitante de contatos EXTERNOS (criada pela
# migração ti_whatsapp_canal_controle_e_conta_externa). O worker a localiza por
# este e-mail. O nome/telefone real do contato fica em ti_chamados.contato_externo.
WHATSAPP_PERFIL_EXTERNO_EMAIL=whatsapp-externo@sistema.teguniao.com.br

# Bucket de Storage dos anexos (mesmo do app).
WHATSAPP_BUCKET=ti-chamados

# Intervalos de polling (ms)
WHATSAPP_POLL_COMANDO_MS=4000
WHATSAPP_POLL_SAIDA_MS=10000
